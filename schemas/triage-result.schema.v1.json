{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TriageResult",
  "description": "Versioned triage output for Control Center ingestion.",
  "type": "object",
  "required": [
    "schema_version",
    "scanned_at",
    "eth_price_used",
    "eth_price_source",
    "triage_tool_version",
    "proof_dir",
    "total_proofs",
    "has_critical",
    "has_high",
    "critical_count",
    "high_count",
    "medium_count",
    "total_usd_impact",
    "proofs",
    "summary_text"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "scanned_at": { "type": "string", "format": "date-time" },
    "eth_price_used": { "type": "string", "minLength": 1 },
    "eth_price_source": { "type": "string", "enum": ["env", "remote", "fallback"] },
    "triage_tool_version": { "type": "string", "minLength": 1 },
    "proof_dir": { "type": "string", "minLength": 1 },
    "total_proofs": { "type": "integer", "minimum": 0 },
    "has_critical": { "type": "boolean" },
    "has_high": { "type": "boolean" },
    "critical_count": { "type": "integer", "minimum": 0 },
    "high_count": { "type": "integer", "minimum": 0 },
    "medium_count": { "type": "integer", "minimum": 0 },
    "total_usd_impact": { "type": "string", "minLength": 1 },
    "proofs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "proof_hash",
          "dedupe_key",
          "content_hash",
          "eth_price_used",
          "eth_price_source",
          "chain",
          "block",
          "detector",
          "userNet",
          "poolNet",
          "usd_user",
          "usd_pool",
          "usd_impact",
          "severity"
        ],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "proof_hash": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
          "dedupe_key": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
          "content_hash": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
          "eth_price_used": { "type": "string", "minLength": 1 },
          "eth_price_source": { "type": "string", "enum": ["env", "remote", "fallback"] },
          "chain": { "type": "string", "minLength": 1 },
          "block": { "type": "integer", "minimum": 0 },
          "detector": { "type": "string", "minLength": 1 },
          "userNet": { "type": "string", "minLength": 1 },
          "poolNet": { "type": "string", "minLength": 1 },
          "usd_user": { "type": "string", "minLength": 1 },
          "usd_pool": { "type": "string", "minLength": 1 },
          "usd_impact": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium"] },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "finding_id": { "type": "string" },
          "protocol": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary_text": { "type": "string" }
  },
  "additionalProperties": false
}

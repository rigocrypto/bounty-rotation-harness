# Required archive RPC endpoints
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Optional explicit ETH price for USD calculations
ETH_PRICE_USD=3400

# Optional: fetch live ETH price from Coingecko when ETH_PRICE_USD is empty
FETCH_ETH_PRICE=0

# Optional pool TVL context for external reporting
POOL_TVL_USD=50000000

# Stripe billing (managed service only)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_GROWTH_PRICE_ID=price_growth_replace_me
STRIPE_REGRESSION_PRO_PRICE_ID=price_regression_pro_replace_me
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_replace_me
BILLING_PORTAL_RETURN_URL=https://managed.example.com/billing
BILLING_PORTAL_API_TOKEN=replace-with-long-random-token
BILLING_DB_PATH=data/billing.db


FROM node:20-bullseye

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ENV NODE_ENV=production
ENV MANAGED_PORT=8787

RUN addgroup --system gmxaudit \
    && adduser --system --ingroup gmxaudit gmxaudit \
    && chown -R gmxaudit:gmxaudit /app
USER gmxaudit

EXPOSE 8787

CMD ["sh", "-c", "npm run managed:scheduler -- --client all & npm run managed:serve"]
